rules_version = '2';

// Regras do Firebase Storage — SeniorEase (projeto: seniorease-backend)
// Princípio: cada utilizador só lê/escreve a sua própria foto de perfil.
service firebase.storage {
  match /b/{bucket}/o {

    // profile_photos/{userId} — foto de perfil (1 ficheiro por utilizador)
    match /profile_photos/{userId} {
      // Leitura permitida ao próprio (a app usa o downloadURL autenticado).
      allow read: if request.auth != null && request.auth.uid == userId;

      // Escrita apenas pelo dono, só imagens e até 5 MB.
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
