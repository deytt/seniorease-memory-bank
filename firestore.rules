rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users — cada utilizador acede apenas ao seu próprio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // tasks — filtradas por userId no documento
    match /tasks/{taskId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;

      // steps — legado: sub-collection antiga do modo guiado.
      // O contrato atual (ADR-023) guarda steps como array no documento da tarefa.
      // Mantido para leitura/limpeza de dados históricos.
      match /steps/{stepId} {
        allow read, write: if request.auth != null;
      }
    }

    // preferences — documento 1:1 com o utilizador (ID == userId)
    match /preferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // onboarding — documento 1:1 com o utilizador (ID == userId)
    // Guarda o estado da boas-vindas inicial do Tour Guiado (cross-device/web).
    match /onboarding/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // reminders — filtrados por userId no documento
    match /reminders/{reminderId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // history — eventos de atividade, filtrados por userId no documento
    match /history/{historyId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // notifications — histórico de pushes enviados (escrita exclusiva do Admin SDK)
    // O utilizador pode ler apenas as suas próprias notificações.
    match /notifications/{notifId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow write: if false; // escrita exclusiva via Admin SDK (Cloud Functions)
    }

    // fcmTokens — subcollection do utilizador; só o dono pode ler/escrever
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
