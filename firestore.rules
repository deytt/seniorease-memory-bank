rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users — cada utilizador acede apenas ao seu próprio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // tasks — filtradas por userId no documento
    match /tasks/{taskId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;

      // steps — sub-collection de passos do modo guiado
      match /steps/{stepId} {
        allow read, write: if request.auth != null;
      }
    }

    // preferences — documento 1:1 com o utilizador (ID == userId)
    match /preferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // onboarding — documento 1:1 com o utilizador (ID == userId)
    // Guarda o estado da boas-vindas inicial do Tour Guiado (cross-device/web).
    match /onboarding/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // reminders — filtrados por userId no documento
    match /reminders/{reminderId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }
  }
}
