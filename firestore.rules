rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // users — cada utilizador acede apenas ao seu próprio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // tasks — filtradas por userId no documento
    match /tasks/{taskId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // steps — sub-collection de passos do modo guiado
      match /steps/{stepId} {
        allow read, write: if request.auth != null;
      }
    }

    // preferences — documento 1:1 com o utilizador (ID == userId)
    match /preferences/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // reminders — filtrados por userId no documento
    match /reminders/{reminderId} {
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }
  }
}
